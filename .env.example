# ProductSnap Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Google OAuth Configuration
# ===========================================
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create a new project or select existing
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ===========================================
# Security Keys
# ===========================================
# Generate secure random strings for these values
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# JWT Secret (32+ characters recommended)
JWT_SECRET=generate_a_secure_32_char_jwt_secret_here

# Encryption Key for API Keys (exactly 32 characters for AES-256)
ENCRYPTION_KEY=generate_exactly_32_char_key_here

# Session Secret
SESSION_SECRET=generate_a_secure_session_secret_here

# ===========================================
# Admin Configuration
# ===========================================
# The first user with this email will be assigned admin role
ADMIN_EMAIL=your_admin_email@example.com

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
NODE_ENV=development
